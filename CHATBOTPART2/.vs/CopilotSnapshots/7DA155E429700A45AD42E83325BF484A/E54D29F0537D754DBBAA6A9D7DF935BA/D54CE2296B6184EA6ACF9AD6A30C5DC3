<Window x:Class="CHATBOTPART2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CHATBOTPART2"
        mc:Ignorable="d"
        Title="Cybersecurity Awareness Bot" Height="600" Width="1000" MinHeight="480" MinWidth="800"
        Loaded="Window_Loaded">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.ColumnSpan="2"
                   Text="CYBERSECURITY AWARENESS BOT"
                   FontSize="22"
                   FontWeight="Bold"
                   Foreground="#0B5FFF"
                   HorizontalAlignment="Center"
                   Margin="6"/>

        <!-- Sidebar: Topics -->
        <Border Grid.Row="1" Grid.Column="0" Margin="6" Padding="8" Background="#F5F7FA" CornerRadius="6">
            <StackPanel>
                <TextBlock Text="Topics" FontSize="18" FontWeight="SemiBold" Margin="2" />
                <Separator Margin="0,4" />
                <Button x:Name="PasswordsButton" Content="Passwords" Tag="password" Margin="0,4" Click="TopicButton_Click" />
                <Button x:Name="PhishingButton" Content="Phishing" Tag="phishing" Margin="0,4" Click="TopicButton_Click" />
                <Button x:Name="ScamsButton" Content="Scams" Tag="scam" Margin="0,4" Click="TopicButton_Click" />
                <Button x:Name="PrivacyButton" Content="Privacy" Tag="privacy" Margin="0,4" Click="TopicButton_Click" />
                <Button x:Name="BankingButton" Content="Banking" Tag="banking" Margin="0,4" Click="TopicButton_Click" />
                <Button x:Name="VpnButton" Content="VPN" Tag="vpn" Margin="0,4" Click="TopicButton_Click" />
                <Button x:Name="RansomwareButton" Content="Ransomware" Tag="ransomware" Margin="0,4" Click="TopicButton_Click" />
                <Button x:Name="SocialEngineeringButton" Content="Social Engineering" Tag="social engineering" Margin="0,4" Click="TopicButton_Click" />
                <Separator Margin="6,8,6,6" />
                <Button Content="Exit" Margin="0,8,0,0" Background="#E53935" Foreground="White" Click="ExitButton_Click" />
               
            </StackPanel>
        </Border>

        <!-- Chat area -->
        <Border Grid.Row="1" Grid.Column="1" Margin="10" Padding="8" Background="WhiteSmoke" CornerRadius="6">
            <Grid>
                <RichTextBox x:Name="ChatArea" Background="Black" Foreground="White" FontSize="15" IsReadOnly="True" />
            </Grid>
        </Border>

        <!-- Input area -->
        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="8" HorizontalAlignment="Stretch">
            <TextBox x:Name="UserInput" FontSize="15" Width="500" Height="42" VerticalContentAlignment="Center" Margin="0,0,8,0" KeyDown="UserInput_KeyDown" />
            <Button Content="Send" Width="120" Height="42" Margin="0,0,8,0" Click="SendButton_Click" Background="#0B5FFF" Foreground="White" />
        </StackPanel>
    </Grid>
</Window>
