        };

        // Map common synonyms/variants to canonical topics
        private readonly Dictionary<string, string> synonymMap = new(StringComparer.OrdinalIgnoreCase)
        {
            { "passwords", "password" },
            { "pwd", "password" },
            { "passcode", "password" },
            { "2fa", "password" },
            { "two-factor", "password" },
            { "two factor", "password" },
            { "one-time password", "scam" },
