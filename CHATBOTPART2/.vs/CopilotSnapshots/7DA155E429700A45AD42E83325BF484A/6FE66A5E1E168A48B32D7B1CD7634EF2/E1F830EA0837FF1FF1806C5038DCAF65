<Window x:Class="CHATBOTPART2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CHATBOTPART2"
        mc:Ignorable="d"
        Title="MainWindow" Height="500" Width="900">
    <Grid Margin="0,15,15,15" HorizontalAlignment="Right" Width="770">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="CYBERSECURITY AWARENESS BOT"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="Blue"
                   HorizontalAlignment="Center"
                   Margin="10"/>

        <RichTextBox x:Name="ChatArea"
                     Grid.Row="1"
                     Background="Black"
                     Foreground="White"
                     FontSize="16"
                     Margin="10"
                     IsReadOnly="True"/>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    Margin="10">

            <TextBox x:Name="UserInput"
                     Width="700"
                     Height="40"
                     FontSize="16"
                     Margin="0,0,10,0"/>
            <Button Content="Send"
                    Width="180"
                    Height="40"
                    Background="Red"
                    Click="SendButton_Click"/>

        </StackPanel>
    </Grid>
</Window>
