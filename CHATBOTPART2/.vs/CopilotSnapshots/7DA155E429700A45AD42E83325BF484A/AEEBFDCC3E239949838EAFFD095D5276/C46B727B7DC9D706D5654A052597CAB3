        public string GetResponse(string input)
        {
            if (string.IsNullOrWhiteSpace(input))
            {
                return "❌ Please enter a valid message.";
            }
            input = input.ToLower().Trim();

            // If we're expecting a follow-up referring to the last topic, handle it first
            if (expectingFollowUp && !string.IsNullOrEmpty(LastTopic))
            {
                var follow = ResolveFollowUp(input);
                if (!string.IsNullOrEmpty(follow))
                {
                    return follow;
                }
            }

            // Quick replies / menu
            if (input == "yes" || input == "y" || input == "menu" || input == "topics" || input.Contains("show topics") || input.Contains("show me topics") || input.Contains("list topics"))
            {
                return GetTopicsList();
            }

            // Detect sentiment first
            DetectSentiment(input, out string moodResponse);
            if (!string.IsNullOrEmpty(moodResponse))
            {
                return moodResponse;
            }

            // Normalize: remove common punctuation for token matching
            var normalized = Regex.Replace(input, "[.,!?;:]", "").ToLowerInvariant();
            var tokens = normalized.Split(new[] { ' ', '\t', '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries);

            // Scoring: count matches for each canonical topic
            var scores = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase);

            foreach (var token in tokens)
            {
                // direct match with canonical keywords
                foreach (var key in keywordResponses.Keys)
                {
                    if (Regex.IsMatch(token, "^" + Regex.Escape(key) + "$", RegexOptions.IgnoreCase))
                    {
                        scores[key] = scores.GetValueOrDefault(key) + 1;
                    }
                }

                // synonyms
                if (synonymMap.TryGetValue(token, out var mapped))
                {
                    scores[mapped] = scores.GetValueOrDefault(mapped) + 2; // weight synonyms a bit higher
                }
            }

            // Also check for multi-word phrases in the original normalized input
            foreach (var kv in synonymMap)
            {
                if (normalized.Contains(kv.Key, StringComparison.OrdinalIgnoreCase))
                {
                    scores[kv.Value] = scores.GetValueOrDefault(kv.Value) + 2;
                }
            }

            // Choose best scoring topic
            if (scores.Count > 0)
            {
                var best = scores.OrderByDescending(k => k.Value).First();
                if (best.Value > 0 && keywordResponses.ContainsKey(best.Key))
                {
                    LastTopic = best.Key;
                    var responses = keywordResponses[best.Key];

                    // If the user explicitly asked for details or used the topic name alone, return a detailed explanation
                    bool wantsDetail = input == best.Key ||
                                       input.Contains("explain") ||
                                       input.Contains("what is") ||
                                       input.Contains("details") ||
                                       input.Contains("tell me more") ||
                                       input.Contains("how does") ||
                                       input.Contains("information about") ||
                                       input.Contains("more info");

                    bool wantsExamples = input.Contains("example") || input.Contains("examples") || input.Contains("show me") || input.Contains("for example");
                    bool wantsMitigation = input.Contains("mitigation") || input.Contains("prevent") || input.Contains("how to") || input.Contains("steps") || input.Contains("protect");

                    if (wantsExamples && topicExamples.TryGetValue(best.Key, out var examples))
                    {
                        var detailPart = topicDetails.ContainsKey(best.Key) ? topicDetails[best.Key] : string.Empty;
                        expectingFollowUp = true;
                        lastResponseCategory = "example";
                        return examples + "\n\n" + detailPart;
                    }

                    if (wantsMitigation && topicDetails.TryGetValue(best.Key, out var mitigationDetail))
                    {
                        // Provide a mitigation-focused response
                        var mitigation = "\n\nMitigation steps: ";
                        switch (best.Key.ToLowerInvariant())
                        {
                            case "password":
                                mitigation += "use unique passphrases, enable MFA, use a trusted password manager, enable account alerts";
                                break;
                            case "phishing":
                                mitigation += "verify sender, don't click unknown links, use email filters, confirm requests via phone";
                                break;
                            case "privacy":
                                mitigation += "review privacy settings, limit sharing, use privacy tools and track permissions";
                                break;
                            case "scam":
                                mitigation += "verify callers, never share OTPs, contact institutions via official channels";
                                break;
                            case "banking":
                                mitigation += "use official apps, enable alerts, avoid transactions on public WiFi";
                                break;
                            case "vpn":
                                mitigation += "choose reputable VPN, review privacy policy, avoid free VPNs";
                                break;
                            case "ransomware":
                                mitigation += "maintain offline backups, update systems, use endpoint protection and caution with attachments";
                                break;
                            case "social engineering":
                                mitigation += "verify identities, use strict approval workflows, train staff regularly";
                                break;
                            default:
                                mitigation += "follow security best practices";
                                break;
                        }

                        expectingFollowUp = true;
                        lastResponseCategory = "mitigation";
                        return mitigationDetail + mitigation;
                    }

                    if (wantsDetail && topicDetails.TryGetValue(best.Key, out var detail))
                    {
                        // Provide the detailed explanation plus a short actionable checklist
                        var checklist = "\n\nQuick checklist: ";
                        switch (best.Key.ToLowerInvariant())
                        {
                            case "password":
                                checklist += "use unique passphrases, enable MFA, use a password manager";
                                break;
                            case "phishing":
                                checklist += "verify senders, hover links, don't enable macros, report suspicious emails";
                                break;
                            case "privacy":
                                checklist += "review privacy settings, limit public data, audit app permissions";
                                break;
                            case "scam":
                                checklist += "don't share OTPs, verify offers, report scams to authorities";
                                break;
                            case "banking":
                                checklist += "enable alerts, use official apps, monitor statements, avoid public WiFi";
                                break;
                            case "vpn":
                                checklist += "choose reputable VPNs, check privacy policy, avoid free VPNs";
                                break;
                            case "ransomware":
                                checklist += "maintain offline backups, patch systems, restrict privileges";
                                break;
                            case "social engineering":
                                checklist += "verify identities, follow approval workflows, train staff";
                                break;
                            default:
                                checklist += "follow best security practices";
                                break;
                        }

                        expectingFollowUp = true;
                        lastResponseCategory = "detail";
                        return detail + checklist;
                    }

                    // Otherwise return a short tip and suggest asking for details
                    var resp = responses[random.Next(responses.Count)];
                    // set follow-up state so user can ask 'another tip' or 'tell me more'
                    expectingFollowUp = true;
                    lastResponseCategory = "tip";
                    return resp;
                }
            }

            if (input.Contains("another tip") ||
                input.Contains("tell me more") ||
                input.Contains("explain more"))
            {
                if (!string.IsNullOrEmpty(LastTopic) && keywordResponses.ContainsKey(LastTopic))
                {
                    var responses = keywordResponses[LastTopic];
                    return responses[random.Next(responses.Count)];
                }
            }

            if (input.Contains("how are you"))
            {
                return $"I'm doing great, {UserName}!";
            }

            // Greetings and general intents
            if (Regex.IsMatch(input, "\b(hi|hello|hey|good morning|good afternoon|good evening)\b", RegexOptions.IgnoreCase))
            {
                return PickRandom(generalResponses["greeting"]);
            }

            if (Regex.IsMatch(input, "\b(thanks|thank you|cheers)\b", RegexOptions.IgnoreCase))
            {
                return PickRandom(generalResponses["thanks"]);
            }

            if (input.Contains("help") || input.Contains("what can i ask") || input.Contains("what can i ask?"))
            {
                return PickRandom(generalResponses["help"]);
            }

            if (input.Contains("purpose") || input.Contains("what do you do"))
            {
                return PickRandom(generalResponses["purpose"]);
            }

            return PickRandom(unknownResponses);
        }

        private void DetectSentiment(string input, out string response)
        {
            response = string.Empty;

            if (input.Contains("worried", StringComparison.OrdinalIgnoreCase))
            {
                if (sentimentResponses.TryGetValue("worried", out var list))
                {
                    response = PickRandom(list);
                }
                return;
            }

            if (input.Contains("frustrated", StringComparison.OrdinalIgnoreCase))
            {
                if (sentimentResponses.TryGetValue("frustrated", out var list))
                {
                    response = PickRandom(list);
                }
                return;
            }

            if (input.Contains("curious", StringComparison.OrdinalIgnoreCase))
            {
                if (sentimentResponses.TryGetValue("curious", out var list))
                {
                    response = PickRandom(list);
                }
            }
        }

        private string PickRandom(List<string> options)
        {
            if (options == null || options.Count == 0) return string.Empty;
            return options[random.Next(options.Count)];
        }

        private string PickRandomOrFallback(List<string>? options, string fallback)
        {
            if (options == null || options.Count == 0) return fallback;
            return options[random.Next(options.Count)];
        }

        private string ResolveFollowUp(string input)
        {
            // If user declines further info
            if (Regex.IsMatch(input, "\b(no|not now|later|thanks|thank you)\b", RegexOptions.IgnoreCase))
            {
                expectingFollowUp = false;
                lastResponseCategory = string.Empty;
                return "Alright — let me know if you want to discuss another topic.";
            }

            // If user asks for an example after a previous reply
            if (Regex.IsMatch(input, "\b(example|examples|for example|show me)\b", RegexOptions.IgnoreCase))
            {
                if (!string.IsNullOrEmpty(LastTopic) && topicExamples.TryGetValue(LastTopic, out var ex))
                {
                    expectingFollowUp = true; // still able to follow up
                    lastResponseCategory = "example";
                    return ex;
                }
            }

            // If user wants mitigation steps
            if (Regex.IsMatch(input, "\b(mitigat|prevent|how to|steps|protect)\b", RegexOptions.IgnoreCase))
            {
                if (!string.IsNullOrEmpty(LastTopic) && topicDetails.TryGetValue(LastTopic, out var detail))
                {
                    expectingFollowUp = true;
                    lastResponseCategory = "mitigation";
                    // Provide short mitigation tailored to LastTopic
                    var mitigation = GetMitigationFor(LastTopic);
                    return detail + "\n\n" + mitigation;
                }
            }

            // If user expresses confusion or asks for clarification, provide detailed explanation and mitigation
            if (Regex.IsMatch(input, "\b(don'?t understand|dont understand|confus|i'?m lost|i am lost|i dont know|can you explain|explain this|clarify|more detail|more details|what does .* mean)\b", RegexOptions.IgnoreCase))
            {
                if (!string.IsNullOrEmpty(LastTopic) && topicDetails.TryGetValue(LastTopic, out var detail))
                {
                    expectingFollowUp = true;
                    lastResponseCategory = "detail";
                    var mitigation = GetMitigationFor(LastTopic);
                    var examples = topicExamples.TryGetValue(LastTopic, out var exx) ? "\n\nExample:\n" + exx : string.Empty;
                    return detail + "\n\n" + mitigation + examples;
                }
            }

            // If user asks for another tip
            if (Regex.IsMatch(input, "\b(another tip|another|more tips|tell me more|more info)\b", RegexOptions.IgnoreCase))
            {
                if (!string.IsNullOrEmpty(LastTopic) && keywordResponses.TryGetValue(LastTopic, out var list))
                {
                    var next = GetMoreTip(LastTopic);
                    expectingFollowUp = true;
                    lastResponseCategory = "tip";
                    return next;
                }
            }

            // Pronoun resolution: if user says 'it' or 'that'
            if (Regex.IsMatch(input, "\b(it|that|this)\b", RegexOptions.IgnoreCase))
            {
                if (!string.IsNullOrEmpty(LastTopic) && topicDetails.TryGetValue(LastTopic, out var detail))
                {
                    return detail;
                }
            }

            return string.Empty; // not handled here
        }

        private string GetMoreTip(string topic)
        {
            if (!keywordResponses.TryGetValue(topic, out var list) || list.Count == 0)
                return "I don't have more tips on that right now.";

            // Return a random tip different from the last returned if possible
            return list[random.Next(list.Count)];
        }

        private string GetMitigationFor(string topic)
        {
            switch (topic.ToLowerInvariant())
            {
                case "password":
                    return "Mitigation steps: use unique passphrases, enable MFA, use password manager, enable account alerts.";
                case "phishing":
                    return "Mitigation steps: verify sender, hover links, don't enable macros, use email filters.";
                case "privacy":
                    return "Mitigation steps: review privacy settings, limit public sharing, audit app permissions.";
                case "scam":
                    return "Mitigation steps: never share OTPs, verify offers independently, report suspicious activity.";
                case "banking":
                    return "Mitigation steps: use official apps, enable alerts, avoid public WiFi for transactions.";
                case "vpn":
                    return "Mitigation steps: choose reputable VPNs, check privacy policy, avoid free VPNs.";
                case "ransomware":
                    return "Mitigation steps: maintain offline backups, patch systems, restrict privileges.";
                case "social engineering":
                    return "Mitigation steps: verify identities, strict approval workflows, train staff regularly.";
                default:
                    return "Mitigation steps: follow security best practices.";
            }
        }

        public bool ShouldExit(string input)
        {
            return input.ToLower() switch
            {
                "exit" or "quit" or "bye" => true,
                _ => false
            };
        }

        private string GetTopicsList()
        {
            return "Topics: " + string.Join(", ", topics);
        }
